---
import CmdHeader from "../components/CmdHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteURL } from "../utils/getSiteUrl";
const desc = "The page does not exists";
---

<BaseLayout title={"Page Not Found"} description={desc}>
    <CmdHeader
        slot="header"
        cmd={""}
        title={"sudo rm -rf --no-preserve-root"}
    />

    <Fragment slot="main" aria-hidden="true">
        <p class="main-404">
            Oups!<br />Erreur 404, page non trouvée.<br /><small aria-hidden="true"
                >S'il vous plait, n'écrivez <strong>JAMAIS</strong> cette commande sur un terminal d'un système UNIX !</small
            >
        </p>
    </Fragment>
</BaseLayout>

<style lang="scss">
    .main-404 {
        text-align: center;
        font-size: var(--fs-3);
        & small {
            font-size: var(--fs-0);
        }
    }
</style>
